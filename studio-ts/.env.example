# ===========================================
# HAUSS PARIS - Environment Variables
# ===========================================
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to version control

# ===========================================
# Email Service (Resend)
# ===========================================
# Get your API key at https://resend.com
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# Email address to receive contact form notifications
# Defaults to contact@haussparis.com if not set
NOTIFICATION_EMAIL=contact@haussparis.com

# ===========================================
# Analytics (Optional)
# ===========================================
# Google Analytics Measurement ID
# Get yours at https://analytics.google.com
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# ===========================================
# Google Search Console (Optional)
# ===========================================
# Verification code for Google Search Console
# Get yours at https://search.google.com/search-console
# GOOGLE_SITE_VERIFICATION=your-verification-code
